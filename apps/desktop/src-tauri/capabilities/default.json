{
  "identifier": "default",
  "description": "Default capabilities for Cabinet",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "process:default",
    "process:allow-exit",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "dialog:allow-message"
  ]
}
