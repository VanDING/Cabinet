{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Cabinet",
  "version": "0.9.0",
  "identifier": "com.cabinet.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm --filter @cabinet/server bundle && node scripts/copy-server.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Cabinet — AI Collaboration",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Cabinet AI Collaboration"
    },
    "security": {
      "dangerousDisableAssetCspModification": true,
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000 http://tauri.localhost:3000 ws://localhost:3000 ws://tauri.localhost:3000 wss://localhost:3000 http://ipc.localhost https://api.open-meteo.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: https://tile.openstreetmap.org; frame-src 'self' blob: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/node-portable.exe", "resources/server-dist"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/VanDING/Cabinet/releases/latest/download/latest.json"],
      "pubkey": "REPLACE_WITH_GENERATED_PUBLIC_KEY (see docs/signing-guide.md)",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
