{
  "name": "@cabinet/desktop",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:theme": "npx tsx src/themes/generate-css.ts",
    "dev": "npm run gen:theme && vite",
    "build": "npm run gen:theme && tsc -b && vite build && node scripts/copy-server.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@cabinet/types": "workspace:*",
    "@cabinet/ui": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "highlight.js": "^11.11.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cabinet/server": "workspace:*",
    "@tauri-apps/cli": "^2.11.1",
