{
  "name": "@cabinet/types",
  "version": "1.0.0-alpha.1",
  "description": "Shared TypeScript types for the Cabinet AI collaboration framework",
  "keywords": [
    "cabinet",
    "ai",
    "types",
    "multi-agent",
    "collaboration",
    "decision"
  ],
  "author": "VanDING",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VanDING/Cabinet.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
