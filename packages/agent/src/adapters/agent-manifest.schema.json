{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cabinet.dev/schemas/agent-manifest.json",
  "title": "Cabinet Agent Manifest",
  "description": "Standard declaration format for external agents registering with Cabinet.",
  "type": "object",
  "required": ["agent_id", "display_name", "version", "protocol"],
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Unique machine-readable identifier (e.g. 'claude-code-v1').",
      "pattern": "^[a-z0-9_-]+$"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name (e.g. 'Claude Code')."
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this manifest.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.]+)?$"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this agent does."
    },
    "protocol": {
      "type": "string",
      "enum": ["a2a", "cli"],
      "description": "Communication protocol used by this agent."
    },
    "configSource": {
      "type": "string",
      "enum": ["cabinet_managed", "agent_native"],
      "default": "agent_native",
      "description": "How this agent's model/API configuration is managed."
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "input_schema": { "type": "object" },
          "output_schema": { "type": "object" },
          "security_level": {
            "type": "string",
            "enum": ["read_only", "light_write", "moderate", "cost", "destructive"]
          }
        }
      }
    },
    "connection": {
      "type": "object",
      "oneOf": [{ "$ref": "#/$defs/a2aConnection" }, { "$ref": "#/$defs/cliConnection" }]
    }
  },
  "$defs": {
    "a2aConnection": {
      "type": "object",
      "required": ["base_url"],
      "properties": {
        "base_url": { "type": "string", "format": "uri" },
        "health_check_url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "properties": {
            "type": { "enum": ["api_key", "oauth"] },
            "header": { "type": "string" },
            "env_var": { "type": "string" }
          }
        },
        "timeout_ms": { "type": "integer", "minimum": 1000, "default": 120000 },
        "max_retries": { "type": "integer", "minimum": 0, "default": 2 }
      }
    },
    "cliConnection": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "description": "CLI command to execute." },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["--print"]
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "permission_mode": {
          "type": "string",
          "enum": ["auto", "conservative", "default", "plan", "acceptEdits", "bypassPermissions"]
        },
        "detect_command": { "type": "string" },
        "install_command": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 1000, "default": 120000 },
        "max_retries": { "type": "integer", "minimum": 0, "default": 2 }
      }
    }
  }
}
